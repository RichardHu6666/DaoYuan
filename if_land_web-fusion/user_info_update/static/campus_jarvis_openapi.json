{
  "openapi": "3.0.3",
  "info": {
    "title": "Campus Jarvis Plugin",
    "version": "0.1.0",
    "description": "Campus Jarvis 校园信息智能助手插件。用于通过自然语言查询校园通知、竞赛、讲座、DDL、办事入口和个性化推荐。"
  },
  "servers": [
    {
      "url": "https://director-multimedia-headlines-tear.trycloudflare.com",
      "description": "Campus Jarvis fusion public endpoint"
    }
  ],
  "tags": [
    {
      "name": "CampusJarvis",
      "description": "校园信息问答"
    }
  ],
  "paths": {
    "/rokid/plugin/ask": {
      "post": {
        "tags": [
          "CampusJarvis"
        ],
        "operationId": "askCampusJarvis",
        "summary": "向 Campus Jarvis 提问",
        "description": "接收用户的自然语言问题，返回 Campus Jarvis 对校园信息、DDL、通知、竞赛、讲座或办事入口的回答。",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "query"
                ],
                "properties": {
                  "query": {
                    "type": "string",
                    "description": "用户自然语言问题，例如：今天有什么 DDL？近期我感兴趣的竞赛有哪些？",
                    "minLength": 1
                  },
                  "user_id": {
                    "type": "string",
                    "description": "可选，Campus Jarvis 用户 UUID。没有用户身份时可以不传。"
                  }
                }
              },
              "examples": {
                "ddl": {
                  "summary": "查询今日 DDL",
                  "value": {
                    "query": "今天有什么 DDL？"
                  }
                },
                "competition": {
                  "summary": "查询个性化竞赛",
                  "value": {
                    "query": "近期我感兴趣的竞赛有哪些？",
                    "user_id": "demo-user"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Campus Jarvis 回答",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean",
                      "description": "请求是否成功"
                    },
                    "answer": {
                      "type": "string",
                      "description": "面向用户展示的回答"
                    },
                    "text": {
                      "type": "string",
                      "description": "兼容字段，内容通常与 answer 相同"
                    },
                    "engine": {
                      "type": "string",
                      "description": "回答使用的后端引擎"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "请求参数错误，例如 query 为空"
          },
          "500": {
            "description": "Campus Jarvis 服务内部错误"
          }
        }
      }
    }
  }
}
